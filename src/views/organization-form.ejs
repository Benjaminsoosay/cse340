<%- include('partials/header') %>

<main>
    <h1><%= title || 'Create New Organization' %></h1>

    <% if (errors && Object.keys(errors).length > 0) { %>
        <div class="error-messages">
            <ul>
                <% for (const key in errors) { %>
                    <li><%= errors[key] %></li>
                <% } %>
            </ul>
        </div>
    <% } %>

    <form action="/organization" method="POST">
        <div>
            <label for="name">Organization Name *</label>
            <input type="text" id="name" name="name" value="<%= organization.name || '' %>" required>
        </div>

        <div>
            <label for="description">Description</label>
            <textarea id="description" name="description" rows="4"><%= organization.description || '' %></textarea>
        </div>

        <div>
            <label for="contact_email">Contact Email</label>
            <input type="email" id="contact_email" name="contact_email" value="<%= organization.contact_email || '' %>">
        </div>

        <div>
            <label for="logo_filename">Logo Filename (optional)</label>
            <input type="text" id="logo_filename" name="logo_filename" value="<%= organization.logo_filename || '' %>">
        </div>

        <button type="submit">Create Organization</button>
    </form>
</main>

<%- include('partials/footer') %>