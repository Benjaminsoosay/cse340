<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create New Organization</title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <%- include('partials/header') %>

    <main>
        <h1>Create a New Organization</h1>
        <form action="/organization" method="POST">
            <label for="name">Name:</label>
            <input type="text" name="name" id="name" required maxlength="150"><br>

            <label for="description">Description:</label>
            <textarea name="description" id="description" rows="4" cols="50" required maxlength="500"></textarea><br>

            <label for="contactEmail">Contact Email:</label>
            <input type="email" name="contactEmail" id="contactEmail" required><br>

            <label for="logoFilename">Logo Filename:</label>
            <input type="text" name="logoFilename" id="logoFilename"><br>

            <button type="submit">Submit</button>
        </form>
        <a href="/organizations">Back to Organizations</a>
    </main>

    <%- include('partials/footer') %>
</body>
</html>