<%- include('partials/header') %>

<main>
    <h1><%= project.title %></h1>
    
    <!-- Edit Project Link -->
    <a href="/edit-project/<%= project.project_id %>" class="btn btn-primary">Edit Project</a>

    <div class="project-details">
        <p><strong>Organization:</strong> 
            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>
        
        <p><strong>Date:</strong> <%= project.date %></p>
        <p><strong>Location:</strong> <%= project.location %></p>
        <p><strong>Description:</strong> <%= project.description %></p>
        
        <!-- Add Category Tags Section -->
        <% if (categories && categories.length > 0) { %>
            <div class="categories-section">
                <p><strong>Categories:</strong></p>
                <div class="category-tags">
                    <% categories.forEach(category => { %>
                        <a href="/category/<%= category.category_id %>" 
                           class="category-tag">
                            <%= category.name %>
                        </a>
                    <% }) %>
                </div>
            </div>
        <% } else { %>
            <p><em>No categories assigned to this project.</em></p>
        <% } %>

        <!-- Edit Categories Link -->
        <p><a href="/project/<%= project.project_id %>/assign-categories">Edit Categories</a></p>
    </div>
    
    <p><a href="/projects">Back to all projects</a></p>
</main>

<%- include('partials/footer') %>