<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <form action="/edit-organization/<%= organization.id %>" method="POST">
        <div>
            <label for="name">Organization Name:</label>
            <input type="text" id="name" name="name" value="<%= organization.name %>" required>
        </div>

        <div>
            <label for="description">Description:</label>
            <textarea id="description" name="description" rows="4" cols="50" required><%= organization.description %></textarea>
        </div>

        <div>
            <label for="contactEmail">Contact Email:</label>
            <input type="email" id="contactEmail" name="contactEmail" value="<%= organization.contact_email %>" required>
        </div>

        <div>
            <label for="logoFilename">Logo Filename:</label>
            <input type="text" id="logoFilename" name="logoFilename" value="<%= organization.logo_filename %>">
        </div>

        <button type="submit">Update Organization</button>
    </form>

    <p><a href="/organization/<%= organization.id %>">Cancel</a></p>
</main>

<%- include('partials/footer') %>